# Copy to .env and fill in the keys you actually need.
#
# Required:
#   ANTHROPIC_API_KEY — for app-hired (headless) Claude Code workers.
#                      Get one at https://console.anthropic.com.
#                      External `claude` sessions launched in a terminal
#                      use whatever auth your CLI is already configured
#                      with, so this is optional if you only watch
#                      external sessions.
#
# Optional:
#   OPENAI_API_KEY — only used by scripts/video/generate-tts.mjs when
#                    regenerating the intro narration.

ANTHROPIC_API_KEY=sk-ant-xxxxx
OPENAI_API_KEY=sk-xxxxx
