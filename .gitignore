.env
.take-home-token
node_modules/
__pycache__/
.venv/
.DS_Store

# Claude Code session artifacts (worktrees, lock files, scheduled tasks)
.claude/worktrees/
.claude/scheduled_tasks.lock
.claude/scheduled_tasks.json

# Build output (regenerated by `npm run build`)
out/

# Per-user hook config (regenerated by `npm run install-hooks`).
# Absolute paths get baked in by the installer, so this is machine-specific.
.claude/settings.json

# gcloud SDK installs (in case anyone unpacks it inside the repo)
.gcloud/
google-cloud-sdk/
google-cloud-cli-*.tar.gz

# Video pipeline generated artifacts — the pipeline scripts under
# scripts/video/ are committed for reproducibility, but the per-beat TTS
# clips, intermediate recordings, and the final mp4 are large and tied to
# the recording machine. Regenerate with:
#   node scripts/video/generate-tts.mjs
#   ./scripts/video/record.sh
scripts/video/audio/
scripts/video/tmp/
scripts/video/out/
