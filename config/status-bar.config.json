{
  "pollIntervalMs": 300000,
  "wallClockTickMs": 30000,
  "probe": {
    "url": "https://api.anthropic.com/v1/messages",
    "anthropicVersion": "2023-06-01",
    "model": "claude-haiku-4-5",
    "maxTokens": 1,
    "timeoutMs": 8000,
    "userAgent": "claude-code/2.1.86"
  },
  "auth": {
    "keychainService": "Claude Code-credentials",
    "envOauthToken": "ANTHROPIC_OAUTH_TOKEN",
    "envApiKey": "ANTHROPIC_API_KEY"
  },
  "refresh": {
    "command": "claude",
    "args": ["-p", "ping"],
    "timeoutMs": 60000,
    "bufferSeconds": 120
  },
  "modelColors": {
    "opus": "#9c6bd1",
    "sonnet": "#5b9bd5",
    "haiku": "#7fc28f",
    "unknown": "#a89070"
  },
  "modelInitials": {
    "opus": "O",
    "sonnet": "S",
    "haiku": "H",
    "unknown": "?"
  }
}
